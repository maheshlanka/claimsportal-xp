#%RAML 1.0
title: claimsPortal-XPAPI
description:  Claims Portal API for claim creation, claim retrieval, claim data submission,
  file upload/download, and claim payment processing.Updated host details to de deployed as maahi.claimsportal.com
version: V1
protocols:
  - HTTPS
  - HTTP
baseUri: http://localhost:8081/api/{version}

uses:
  common: libraries/common-types.raml
  traitsLib: libraries/common-traits.raml
  claimsLib: libraries/claims-types.raml
  fileLib: libraries/file-types.raml
  paymentLib: libraries/payment-types.raml
  errorTraits: libraries/error-traits.raml

securedBy:
  - basicAuth

securitySchemes:
  basicAuth:
    type: Basic Authentication
    description: Basic Authentication or API Manager policy-based authentication.
/healthCheck:
  get:
    description: This API will get status of the service running
    responses:
      200:
        body:
          application/json:
            example:
              !include /healthCheckSuccessResponse.json

/claims:
  get:
    displayName: Fetch Claims
    description: Fetch claims and return response in JSON, XML, CSV, or multipart format.
    is:
      - traitsLib.clientHeaders
      - traitsLib.pagination
      - traitsLib.dateRange
      - traitsLib.responseFormat
      - errorTraits.standardErrorResponses
    queryParameters:
      claimId:
        type: string
        required: false
        example: "CLM100001"
      policyNumber:
        type: string
        required: false
        example: "POL123456"
      customerId:
        type: string
        required: false
        example: "CUST10001"
      claimStatus:
        type: string
        required: false
        enum: [SUBMITTED, IN_REVIEW, APPROVED, REJECTED, PAID, CANCELLED]
      claimType:
        type: string
        required: false
        enum: [MEDICAL, MOTOR, TRAVEL, LIFE, PROPERTY, OTHER]
    responses:
      200:
        body:
          application/json:
            type: claimsLib.ClaimListResponse
          application/xml:
            example: |
              <claimsResponse>
                <totalRecords>1</totalRecords>
                <page>1</page>
                <pageSize>10</pageSize>
                <claims>
                  <claim>
                    <claimId>CLM100001</claimId>
                    <policyNumber>POL123456</policyNumber>
                    <customerId>CUST10001</customerId>
                    <claimantName>John Tan</claimantName>
                    <claimType>MEDICAL</claimType>
                    <claimStatus>SUBMITTED</claimStatus>
                    <incidentDate>2026-05-01</incidentDate>
                    <claimAmount>2500.50</claimAmount>
                    <currency>HKD</currency>
                  </claim>
                </claims>
              </claimsResponse>
          text/csv:
            example: |
              claimId,policyNumber,customerId,claimantName,claimType,claimStatus,incidentDate,claimAmount,currency
              CLM100001,POL123456,CUST10001,John Tan,MEDICAL,SUBMITTED,2026-05-01,2500.50,HKD
          multipart/form-data:
            properties:
              metadata:
                type: string
                required: true
              claimsFile:
                type: file
                required: false
                fileTypes:
                  - application/json
                  - application/xml
                  - text/csv

  post:
    displayName: Create Claim
    description: Create claim using JSON request payload.
    is:
      - traitsLib.clientHeaders
      - errorTraits.standardErrorResponses
    body:
      application/json:
        type: claimsLib.ClaimCreateRequest
      application/xml:
        example: |
          <claim>
            <policyNumber>POL123456</policyNumber>
            <customerId>CUST10001</customerId>
            <claimantName>John Tan</claimantName>
            <claimType>MEDICAL</claimType>
            <incidentDate>2026-05-01</incidentDate>
            <claimAmount>2500.50</claimAmount>
            <currency>HKD</currency>
          </claim>
      text/csv:
        example: |
          policyNumber,customerId,claimantName,claimType,incidentDate,claimAmount,currency,description
          POL123456,CUST10001,John Tan,MEDICAL,2026-05-01,2500.50,HKD,Hospital claim
      multipart/form-data:
        properties:
          metadata:
            type: string
            required: true
          claimFile:
            type: file
            required: false
            fileTypes:
              - application/pdf
              - image/png
              - image/jpeg
              - text/csv
              - application/xml
    responses:
      201:
        body:
          application/json:
            type: claimsLib.ClaimResponse

  /{claimId}:
    uriParameters:
      claimId:
        type: string
        required: true
        example: "CLM100001"

    get:
      displayName: Fetch Claim By ID
      description: Fetch single claim and return response in JSON, XML, CSV, or multipart format.
      is:
        - traitsLib.clientHeaders
        - traitsLib.responseFormat
        - errorTraits.standardErrorResponses
      responses:
        200:
          body:
            application/json:
              type: claimsLib.ClaimResponse
            application/xml:
              example: |
                <claimResponse>
                  <success>true</success>
                  <message>Claim fetched successfully</message>
                  <claim>
                    <claimId>CLM100001</claimId>
                    <policyNumber>POL123456</policyNumber>
                    <customerId>CUST10001</customerId>
                    <claimantName>John Tan</claimantName>
                    <claimType>MEDICAL</claimType>
                    <claimStatus>IN_REVIEW</claimStatus>
                    <incidentDate>2026-05-01</incidentDate>
                    <claimAmount>2500.50</claimAmount>
                    <currency>HKD</currency>
                  </claim>
                </claimResponse>
            text/csv:
              example: |
                success,message,claimId,policyNumber,customerId,claimantName,claimType,claimStatus,incidentDate,claimAmount,currency
                true,Claim fetched successfully,CLM100001,POL123456,CUST10001,John Tan,MEDICAL,IN_REVIEW,2026-05-01,2500.50,HKD

    put:
      displayName: Update Claim
      is:
        - traitsLib.clientHeaders
        - errorTraits.standardErrorResponses
      body:
        application/json:
          type: claimsLib.ClaimUpdateRequest
      responses:
        200:
          body:
            application/json:
              type: claimsLib.ClaimResponse

/claims/data:
  post:
    displayName: Submit Claim Data - JSON, CSV, XML, Multipart
    description: Submit claim data in JSON, CSV, XML, or multipart format.
    is:
      - traitsLib.clientHeaders
      - errorTraits.standardErrorResponses
    queryParameters:
      sourceSystem:
        type: string
        required: true
        example: "CLAIMS_PORTAL"
      batchId:
        type: string
        required: false
        example: "BATCH20260509001"
      validateOnly:
        type: boolean
        required: false
        default: false
    body:
      application/json:
        type: claimsLib.ClaimCreateRequest

      text/csv:
        example: |
          policyNumber,customerId,claimantName,claimType,incidentDate,claimAmount,currency,description
          POL123456,CUST10001,John Tan,MEDICAL,2026-05-01,2500.50,HKD,Hospital claim

      application/xml:
        example: |
          <claim>
            <policyNumber>POL123456</policyNumber>
            <customerId>CUST10001</customerId>
            <claimantName>John Tan</claimantName>
            <claimType>MEDICAL</claimType>
            <incidentDate>2026-05-01</incidentDate>
            <claimAmount>2500.50</claimAmount>
            <currency>HKD</currency>
          </claim>

      multipart/form-data:
        properties:
          metadata:
            type: string
            required: true
          claimFile:
            type: file
            required: false
            fileTypes:
              - application/pdf
              - image/png
              - image/jpeg
              - text/csv
              - application/xml
    responses:
      202:
        body:
          application/json:
            example:
              success: true
              message: "Claim data accepted for processing"
              batchId: "BATCH20260509001"
              acceptedRecords: 1
              rejectedRecords: 0

/files:
  /upload:
    post:
      displayName: Upload Claim File
      is:
        - traitsLib.clientHeaders
        - errorTraits.standardErrorResponses
      queryParameters:
        claimId:
          type: string
          required: true
          example: "CLM100001"
        documentType:
          type: string
          required: true
          enum: [INVOICE, RECEIPT, MEDICAL_REPORT, ACCIDENT_REPORT, ID_PROOF, POLICY_DOCUMENT, OTHER]
        uploadedBy:
          type: string
          required: true
          example: "john.tan"
      body:
        multipart/form-data:
          properties:
            file:
              type: file
              required: true
              fileTypes:
                - application/pdf
                - image/png
                - image/jpeg
                - text/csv
                - application/xml
            fileName:
              type: string
              required: false
              example: "medical-report.pdf"
            remarks:
              type: string
              required: false
      responses:
        201:
          body:
            application/json:
              type: fileLib.FileUploadResponse

  /download/{fileId}:
    uriParameters:
      fileId:
        type: string
        required: true
        example: "FILE100001"
    get:
      displayName: Download Claim File
      is:
        - traitsLib.clientHeaders
        - errorTraits.standardErrorResponses
      queryParameters:
        claimId:
          type: string
          required: false
          example: "CLM100001"
        downloadFormat:
          type: string
          required: false
          enum: [BINARY, BASE64]
          default: BINARY
      responses:
        200:
          body:
            application/octet-stream:
              description: Binary file download response.
            application/json:
              type: fileLib.FileDownloadResponse

  /metadata/{fileId}:
    uriParameters:
      fileId:
        type: string
        required: true
        example: "FILE100001"
    get:
      displayName: Fetch File Metadata
      is:
        - traitsLib.clientHeaders
        - errorTraits.standardErrorResponses
      responses:
        200:
          body:
            application/json:
              type: fileLib.FileMetadataResponse

/payments:
  post:
    displayName: Initiate Claim Payment
    is:
      - traitsLib.clientHeaders
      - errorTraits.standardErrorResponses
    body:
      application/json:
        type: paymentLib.PaymentRequest
    responses:
      201:
        body:
          application/json:
            type: paymentLib.PaymentResponse

  get:
    displayName: Fetch Payments
    is:
      - traitsLib.clientHeaders
      - traitsLib.pagination
      - traitsLib.dateRange
      - errorTraits.standardErrorResponses
    queryParameters:
      paymentId:
        type: string
        required: false
        example: "PAY100001"
      claimId:
        type: string
        required: false
        example: "CLM100001"
      customerId:
        type: string
        required: false
        example: "CUST10001"
      paymentStatus:
        type: string
        required: false
        enum: [INITIATED, SUCCESS, FAILED, PENDING, CANCELLED]
    responses:
      200:
        body:
          application/json:
            example:
              totalRecords: 1
              page: 1
              pageSize: 10
              payments:
                - success: true
                  paymentId: "PAY100001"
                  claimId: "CLM100001"
                  transactionReference: "TXN202605090001"
                  paymentStatus: SUCCESS
                  message: "Payment processed successfully"
                  paidAmount: 2400.00
                  currency: "HKD"

  /{paymentId}:
    uriParameters:
      paymentId:
        type: string
        required: true
        example: "PAY100001"
    get:
      displayName: Fetch Payment By ID
      is:
        - traitsLib.clientHeaders
        - errorTraits.standardErrorResponses
      responses:
        200:
          body:
            application/json:
              type: paymentLib.PaymentResponse

    /status:
      put:
        displayName: Update Payment Status
        is:
          - traitsLib.clientHeaders
          - errorTraits.standardErrorResponses
        body:
          application/json:
            type: paymentLib.PaymentStatusUpdateRequest
        responses:
          200:
            body:
              application/json:
                type: paymentLib.PaymentResponse